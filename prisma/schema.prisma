generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Task {
    id          Int       @id @default(autoincrement())
    userId      String

    title       String
    description String?
    deadline    DateTime?
    repeat      Repeat    @default(No)
}

enum Repeat {
    No
    Daily
    Weekly
    Monthly
    Yearly
}
